{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-safety.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-bash-contract-guard.sh" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-write-safety.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-state-transition.sh" }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit-safety.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-state-transition.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact-save.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-skill-cleanup.sh" }]
      },
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-phase-checkpoint.sh" }]
      },
      {
        "matcher": "Edit",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-phase-checkpoint.sh" }]
      }
    ],
    "Stop": [
      {
        "_comment": "impl-checkpoint-guard.sh — 5-AND gate guarding /audit handoff back to /impl Step 18 + Phase 3. Independent counter (/tmp/.impl-checkpoint-${SESSION_ID}); release at 3 blocks. Runs BEFORE autopilot-continue.sh and evaluates INDEPENDENTLY in /autopilot context — both hooks may block in the same turn, with asymmetric release thresholds (3 vs 5+) yielding ~8 cumulative attempts before pipeline halt. See hooks/impl-checkpoint-guard.sh header and convergence-addendum.md §13.A-3 for the design rationale.",
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/impl-checkpoint-guard.sh" }]
      },
      {
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/autopilot-continue.sh" }]
      },
      {
        "hooks": [{ "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-stop-log.sh" }]
      }
    ]
  }
}
